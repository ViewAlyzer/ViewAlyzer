{
  "version": 1,
  "name": "Nucleo G474 Zephyr SWO Demo",
  "description": "ViewAlyzer example project for the STM32 Nucleo-G474RE running the Zephyr demo over ST-LINK SWO/ITM with Zephyr threads, sync objects, and user-function events declared explicitly.",
  "targetDevice": "STM32G474RE",
  "transport": {
    "type": "stlink_swo",
    "cpuClockHz": 170000000,
    "interface": "SWD",
    "speedKHz": 4000,
    "resetOnConnect": true,
    "debugServer": "openocd",
    "symbolPollingIntervalMs": 100,
    "swoFreqHz": 2000000,
    "itmPort": 1,
    "stlinkGdbPort": 61234,
    "stlinkSwoPort": 61235,
    "targetDevice": "stm32g4x",
    "stlinkPath": "/home/eddie/st/stm32cubeclt_1.17.0/STLink-gdb-server/bin/ST-LINK_gdbserver",
    "cubeProgrammerPath": "/home/eddie/st/stm32cubeclt_1.17.0/STM32CubeProgrammer/bin",
    "openocdPath": "/media/eddie/Engineering/Projects/ViewAlyzer_Root/external/OpenOCD/src/openocd",
    "openocdScriptsPath": "/media/eddie/Engineering/Projects/ViewAlyzer_Root/external/OpenOCD/tcl",
    "armGdbPath": "/opt/st/stm32cubeclt_1.21.0/GNU-tools-for-STM32/bin/arm-none-eabi-gdb",
    "framing": "none"
  },
  "protocol": {
    "bigEndian": false,
    "rtos": true,
    "rtosType": "Zephyr",
    "userTraces": [
      {
        "id": 42,
        "name": "Sine Value",
        "type": "graph",
        "scaleMin": 0.0,
        "scaleMax": 200.0,
        "colour": "#808080"
      },
      {
        "id": 43,
        "name": "Tick Counter",
        "type": "graph",
        "colour": "#808080"
      },
      {
        "id": 44,
        "name": "Calc Toggle",
        "type": "toggle",
        "colour": "#808080"
      },
      {
        "id": 46,
        "name": "Processed Data",
        "type": "graph",
        "colour": "#808080"
      },
      {
        "id": 47,
        "name": "Shared Counter",
        "type": "graph",
        "colour": "#808080"
      },
      {
        "id": 48,
        "name": "Protected Op",
        "type": "graph",
        "colour": "#808080"
      },
      {
        "id": 49,
        "name": "Calc Shared",
        "type": "graph",
        "colour": "#808080"
      },
      {
        "id": 50,
        "name": "Workload Profile",
        "type": "graph",
        "colour": "#808080"
      },
      {
        "id": 51,
        "name": "Low Prio Access",
        "type": "graph",
        "colour": "#808080"
      },
      {
        "id": 52,
        "name": "Med Prio Access",
        "type": "graph",
        "colour": "#808080"
      },
      {
        "id": 53,
        "name": "High Prio Wait",
        "type": "counter",
        "colour": "#808080"
      },
      {
        "id": 54,
        "name": "Normal Low",
        "type": "graph",
        "colour": "#808080"
      },
      {
        "id": 55,
        "name": "Normal Med",
        "type": "graph",
        "colour": "#808080"
      },
      {
        "id": 56,
        "name": "Normal High",
        "type": "graph",
        "colour": "#808080"
      },
      {
        "id": 60,
        "name": "Sine Float",
        "type": "graph",
        "scaleMin": -1.0,
        "scaleMax": 1.0,
        "colour": "#808080"
      },
      {
        "id": 61,
        "name": "Shared Accum",
        "type": "graph",
        "colour": "#808080"
      },
      {
        "id": 62,
        "name": "HighPrio WaitF",
        "type": "graph",
        "scaleMin": 0.0,
        "scaleMax": 100.0,
        "colour": "#808080"
      },
      {
        "id": 63,
        "name": "Inv Sine Float",
        "type": "graph",
        "scaleMin": -1.0,
        "scaleMax": 1.0,
        "colour": "#808080"
      }
    ],
    "userFunctions": [
      {
        "id": 45,
        "name": "Calc Event"
      }
    ],
    "tasks": [
      {
        "id": 1,
        "name": "blink_tid",
        "priority": 5
      },
      {
        "id": 2,
        "name": "default_tid",
        "priority": 3
      },
      {
        "id": 3,
        "name": "sensor_tid",
