        "name": "wlmgr_tid",
        "priority": 2
      },
      {
        "id": 11,
        "name": "cont_low_tid",
        "priority": 7
      },
      {
        "id": 12,
        "name": "cont_med_tid",
        "priority": 3
      },
      {
        "id": 13,
        "name": "cont_high_tid",
        "priority": 2
      },
      {
        "id": 14,
        "name": "norm_low_tid",
        "priority": 7
      },
      {
