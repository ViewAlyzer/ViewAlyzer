    "isrs": [
      {
        "id": 1,
        "name": "SysTick"
      },
      {
        "id": 2,
        "name": "PendSV"
      }
    ],
    "syncObjects": [
      {
        "id": 1,
        "name": "data_msgq",
        "type": "queue"
      },
      {
        "id": 2,
        "name": "command_msgq",
        "type": "queue"
      },
      {
        "id": 3,
        "name": "shared_resource_mutex",
        "type": "mutex"
      },
      {
        "id": 4,
        "name": "print_mutex",
        "type": "mutex"
      },
      {
        "id": 5,
        "name": "contention_test_mutex",
        "type": "mutex"
      },
      {
        "id": 6,
        "name": "normal_op_mutex",
        "type": "mutex"
      },
      {
        "id": 7,
        "name": "binary_sem",
        "type": "binary_sem"
      },
      {
        "id": 8,
        "name": "counting_sem",
        "type": "counting_sem"
      },
      {
        "id": 9,
